PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production
NOVA_IMAGE_TAG=latest
NOVA_API_BASE_URL=http://sub2api:8080

NOVA_TASK_DB=/app/backend/data/nova-tasks.sqlite
NOVA_IMAGE_DIR=/app/backend/data/nova-images
NOVA_TASK_CONCURRENCY=10

NOVA_MAX_QUEUE_SIZE=50
NOVA_RATE_LIMIT_WINDOW_MS=60000
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_IP=10
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_API_KEY=10
NOVA_MAX_PENDING_TASKS_PER_IP=10
NOVA_MAX_PENDING_TASKS_PER_API_KEY=10
NOVA_RATE_LIMIT_RETRY_AFTER_SECONDS=60

PROMPT_GALLERY_MODE=3
PROMPT_GALLERY_PASSWORD=
